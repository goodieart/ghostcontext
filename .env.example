# Upstream OpenAI-compatible API (LM Studio, Ollama OpenAI shim, cloud, etc.)
GHOSTCONTEXT_UPSTREAM_BASE_URL=http://127.0.0.1:1234/v1
GHOSTCONTEXT_UPSTREAM_API_KEY=lm-studio

# Bind address for the proxy
GHOSTCONTEXT_HOST=0.0.0.0
GHOSTCONTEXT_PORT=8000

# Paths (relative to cwd or absolute)
GHOSTCONTEXT_LOG_DIR=context_logs
GHOSTCONTEXT_CHROMA_PATH=chroma_data
GHOSTCONTEXT_COLLECTION_NAME=ghostcontext_history

# Retrieval
GHOSTCONTEXT_N_RESULTS=3

# Name returned by GET /v1/models (clients may display this)
GHOSTCONTEXT_PROXY_MODEL_ID=ghostcontext

# Optional default when clients omit "model" in JSON body
# GHOSTCONTEXT_DEFAULT_UPSTREAM_MODEL=local-model
